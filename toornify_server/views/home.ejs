<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Welcome to toornify</title>
    <%- include('partials/header.ejs') %>

    <style>
      @keyframes fadeIn {
        from {
          opacity: 0;
          transform: translateY(20px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      .fade-in {
        animation: fadeIn 1.5s ease-out;
      }
    </style>
  </head>
  <body
    style="
      background: linear-gradient(to bottom right, #1e1b4b, #000000, #3b0764);
    "
  >

    <div
      class="container-fluid d-flex justify-content-center align-items-center vh-100"
    >
      <div>
        <h1 class="text-white fs-1 fade-in">Welcome to Toornify!</h1>
        <h3 class="text-white fs-2 fade-in">
          Suite of Powerful Tools for Tournaments
        </h3>

        <button type="button" class="btn btn-primary mt-5">
          <a href="/about" class="text-white"> Tap to learn more </a>
        </button>
      </div>
    </div>

    <%- include('partials/footer.ejs') %>
  </body>
</html>
