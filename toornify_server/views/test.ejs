<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Test Chat - Toornify</title>
    <%- include('partials/header.ejs') %>
    <script src="/socket.io/socket.io.js"></script>
  </head>
  <body>
    <%- include('partials/navbar.ejs') %>

    <div class="container mt-5">
      <h2 class="text-center mb-4" style="color: var(--primary-neon);">Test Chat Room</h2>

      <div class="row justify-content-center">
        <div class="col-md-8">
          <div class="card" style="background: var(--card-bg); border: 1px solid var(--primary-neon);">
            <div class="card-body">
              <div id="messages" class="mb-3" style="height: 400px; overflow-y: auto; padding: 1rem; background: rgba(0,0,0,0.3); border-radius: 10px;">
                <!-- Messages will appear here -->
              </div>

              <div class="input-group">
                <input id="message" class="form-control" placeholder="Type message" style="background: rgba(26, 26, 46, 0.6); border: 1px solid var(--primary-neon); color: #fff;" />
                <button class="btn btn-gaming" onclick="sendMessage()">Send</button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <script>
      const socket = io();
      const messages = document.getElementById("messages");

      socket.emit("join room", "test-room");

      socket.on("chat message", (data) => {
        const div = document.createElement("div");
        div.textContent = `${data.sender}: ${data.message}`;
        messages.appendChild(div);
      });

      function sendMessage() {
        const message = document.getElementById("message").value;
        socket.emit("chat message", {
          room: "test-room",
          message: message,
          sender: "TestUser",
        });
        document.getElementById("message").value = "";
      }
    </script>
  </body>
</html>
